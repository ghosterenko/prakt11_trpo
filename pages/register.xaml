<Page x:Class="prakt8.pages.register"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:prakt8.pages"
      xmlns:validators="clr-namespace:prakt8.ValidationRules"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="register">
    <StackPanel x:Name="regDoc" Style="{DynamicResource spVert}">
        <Label Content="Фамилия"/>
        <TextBox x:Name="surnameTb">
            <TextBox.Text>
                <Binding Path="Surname" UpdateSourceTrigger="PropertyChanged">
                    <Binding.ValidationRules>
                        <validators:StringValidation/>
                    </Binding.ValidationRules>
                </Binding>
            </TextBox.Text>
        </TextBox>
        <Label Content="Имя"/>
        <TextBox x:Name="nameTb">
            <TextBox.Text>
                <Binding Path="Name" UpdateSourceTrigger="PropertyChanged">
                    <Binding.ValidationRules>
                        <validators:StringValidation/>
                    </Binding.ValidationRules>
                </Binding>
            </TextBox.Text>
        </TextBox>
        <Label Content="Отчество"/>
        <TextBox x:Name="middleTb">
            <TextBox.Text>
                <Binding Path="Middlename" UpdateSourceTrigger="PropertyChanged">
                    <Binding.ValidationRules>
                        <validators:StringValidation/>
                    </Binding.ValidationRules>
                </Binding>
            </TextBox.Text>
        </TextBox>
        <Label Content="Специальность"/>
        <TextBox x:Name="specTb" Text="{Binding Spec, Mode=OneWayToSource}"/>
        <Label Content="Пароль"/>
        <TextBox x:Name="passwordTb" Text="{Binding Pass, Mode=OneWayToSource}"/>
        <Button Content="Регистрация" Click="Button_Click"/>
        <Button x:Name="backBtn" Content="Вернутся на прошлую страницу" Click="backBtn_Click"/>
    </StackPanel>
</Page>
