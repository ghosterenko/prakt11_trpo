<Page x:Class="prakt8.pages.mainPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:prakt8.pages"
      mc:Ignorable="d"
      d:DesignHeight="450" d:DesignWidth="800"
      Title="mainPage">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="50px"/>
            <RowDefinition Height="50px"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="40px"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Style="{DynamicResource spHoriz}">
            <Button x:Name="createPacientBtn" Content="Создать пациента" Click="createPacientBtn_Click"/>
            <Button x:Name="startPriemBtn" Content="Начать прием" Click="startPriemBtn_Click"/>
            <Button x:Name="redactInfoBtn" Content="Изменить информацию" Click="redactInfoBtn_Click"/>
            <Button x:Name="settingBtn" Content="Настройки" Click="settingBtn_Click"/>
        </StackPanel>
        <StackPanel x:Name="docInfo" Grid.Row="1" Style="{DynamicResource spHoriz}">
            <Label Content="{Binding Surname}"/>
            <Label Content="{Binding Name}"/>
            <Label Content="{Binding Middlename}"/>
            <Label Content="{Binding Spec}"/>
        </StackPanel>

        <ListView x:Name="listpac" ItemsSource="{Binding pacients, Mode=OneWay, UpdateSourceTrigger=PropertyChanged}" Grid.Row="2" Style="{DynamicResource MaterialDesignToolVerticalToggleListBox}">
            <ListView.ItemTemplate>
                <DataTemplate>
                    <StackPanel Style="{DynamicResource spVert}">
                        <StackPanel Style="{DynamicResource spHoriz}">
                            <Label Content="ФИО: "/>
                            <Label>
                                <Label.Content>
                                    <MultiBinding StringFormat="{}{0} {1}">
                                        <Binding Path="Surname"/>
                                        <Binding Path="Name"/>
                                        <Binding Path="Middlename"/>
                                    </MultiBinding>
                                </Label.Content>
                            </Label>
                            <Label Content="{Binding Surname}"/>
                            <Label Content="{Binding Name}"/>
                            <Label Content="{Binding Middlename}"/>
                        </StackPanel>
                        <StackPanel Style="{DynamicResource spHoriz}">
                            <Label Content="Дата рождения: "/>
                            <Label Content="{Binding Bday, StringFormat={}{0:dd.MM.yyyy}}"/>
                        </StackPanel>
                        <StackPanel Style="{DynamicResource spHoriz}">
                            <Label Content="Номер телефона: "/>
                            <Label Content="{Binding PhoneNumber, StringFormat={}{0:### ### ## ##}}"/>
                        </StackPanel>
                    </StackPanel>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>



        <StackPanel x:Name="blockDown" Style="{DynamicResource sphorzDown}" Grid.Row="3">
            <Label Content="Всего в списке: " />
            <Label Content="{Binding pacients.Count, UpdateSourceTrigger=PropertyChanged}"/>
        </StackPanel>

    </Grid>
</Page>
