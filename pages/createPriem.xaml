<Page x:Class="prakt8.pages.createPriem"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:prakt8.pages"
      xmlns:validators="clr-namespace:prakt8.ValidationRules"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="createPriem">
    
    <StackPanel x:Name="createsp" Style="{DynamicResource spVert}">
        <Label Content="Фамилия"/>
        <TextBox x:Name="surnameTextBox">
            <TextBox.Text>
                <Binding Path="Surname" UpdateSourceTrigger="PropertyChanged">
                    <Binding.ValidationRules>
                        <validators:StringValidation/>
                    </Binding.ValidationRules>
                </Binding>
            </TextBox.Text>
        </TextBox>
        <ItemsControl Foreground="Red"
              FontSize="12"
              ItemsSource="{Binding ElementName=surnameTextBox, Path=(Validation.Errors)}">
            <ItemsControl.ItemTemplate>
                <DataTemplate>
                    <TextBlock Text="{Binding ErrorContent}" TextWrapping="Wrap"/>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>


        <Label Content="Имя"/>
        <TextBox x:Name="nameTextBox">
            <TextBox.Text>
                <Binding Path="Name" UpdateSourceTrigger="PropertyChanged">
                    <Binding.ValidationRules>
                        <validators:StringValidation/>
                    </Binding.ValidationRules>
                </Binding>
            </TextBox.Text>
        </TextBox>
        <ItemsControl Foreground="Red"
              FontSize="12"
              ItemsSource="{Binding ElementName=nameTextBox, Path=(Validation.Errors)}">
            <ItemsControl.ItemTemplate>
                <DataTemplate>
                    <TextBlock Text="{Binding ErrorContent}" TextWrapping="Wrap"/>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>




        <Label Content="Отчество"/>
        <TextBox x:Name="middlenameTextBox">
            <TextBox.Text>
                <Binding Path="Middlename" UpdateSourceTrigger="PropertyChanged">
                    <Binding.ValidationRules>
                        <validators:StringValidation/>
                    </Binding.ValidationRules>
                </Binding>
            </TextBox.Text>
        </TextBox>
        <ItemsControl Foreground="Red"
              FontSize="12"
              ItemsSource="{Binding ElementName=middlenameTextBox, Path=(Validation.Errors)}">
            <ItemsControl.ItemTemplate>
                <DataTemplate>
                    <TextBlock Text="{Binding ErrorContent}" TextWrapping="Wrap"/>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>



        <Label Content="Дата рождения"/>
        <DatePicker x:Name="bdayDatePick">
            <DatePicker.Text>
                <Binding Path="Bday">
                    <Binding.ValidationRules>
                        <validators:DateTimeValidation/>
                    </Binding.ValidationRules>
                </Binding>
            </DatePicker.Text>
        </DatePicker>
        <ItemsControl Foreground="Red"
              FontSize="12"
              ItemsSource="{Binding ElementName=bdayDatePick, Path=(Validation.Errors)}">
            <ItemsControl.ItemTemplate>
                <DataTemplate>
                    <TextBlock Text="{Binding ErrorContent}" TextWrapping="Wrap"/>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>



        <Label Content="Номер телефона"/>
        <TextBox x:Name="phNumberTextBox">
            <TextBox.Text>
                <Binding Path="PhoneNumber" UpdateSourceTrigger="PropertyChanged">
                    <Binding.ValidationRules>
                        <validators:phoneNumberValidation/>
                    </Binding.ValidationRules>
                </Binding>
            </TextBox.Text>
        </TextBox>
        <ItemsControl Foreground="Red"
              FontSize="12"
              ItemsSource="{Binding ElementName=phNumberTextBox, Path=(Validation.Errors)}">
            <ItemsControl.ItemTemplate>
                <DataTemplate>
                    <TextBlock Text="{Binding ErrorContent}" TextWrapping="Wrap"/>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>


        <Button Content="Создать" Click="Button_Click"/>
        <Button x:Name="exitBtn" Content="Назад" Click="exitBtn_Click"/>
    </StackPanel>
</Page>
